PORT=8082

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=agency
DB_SSLMODE=disable

FRONTEND_URL=http://localhost:3000
LOGO_URL=

# Gateway's public base URL (NOT this service's own port — agency-service
# has no host port mapping and is only reachable via the gateway). Used to
# compose the browser-facing URL for GET /agency/leads/:id/logo.
AGENCY_PUBLIC_URL=http://localhost:8080

RESEND_API_KEY=re_your_key_here
RESEND_FROM=hello@yourdomain.com

# Email that receives new lead notifications and revision request alerts
LEAD_NOTIFICATION_EMAIL=
ADMIN_NOTIFICATION_EMAIL=consultprompts@gmail.com

# Shared secret for POST /webhooks/payment-success (X-Webhook-Secret header).
# The webhook rejects all requests until this is set.
PAYMENT_WEBHOOK_SECRET=
